{smcl}
{com}{sf}{ul off}{txt}{.-}
      name:  {res}<unnamed>
       {txt}log:  {res}/home/research/ca_ed_lab/projects/csac_survey2024/log/explore/tab_questions.smcl
  {txt}log type:  {res}smcl
 {txt}opened on:  {res}21 Aug 2024, 14:44:48
{txt}
{com}. 
. graph drop _all
{txt}
{com}. set more off
{txt}
{com}. set varabbrev off
{txt}
{com}. set graphics off
{txt}
{com}. set scheme s1color
{txt}
{com}. set seed 1984
{txt}
{com}. 
. include $projdir/do/macros_csac.doh 
{txt}
{com}. /* macros for the project */
. 
. #delimit ;
{txt}delimiter now ;
{com}. local fafsa_qs
>     when_heard_fafsa difficulty_apply_finaid
>     ;
{txt}
{com}. local coll_att_qs
>     coll_att_3pt_important coll_att_3pt_worth coll_att_3pt_ready
>     coll_att_5pt_important coll_att_5pt_worth coll_att_5pt_ready
>     ;
{txt}
{com}. local coll_app_qs
>     coll_factor_gpa coll_factor_score coll_factor_service 
>     coll_factor_firstgen coll_factor_extra
> 
>     attend_coll
>     ;
{txt}
{com}. local not_coll_qs
>     ;
{txt}
{com}. local idk_coll_qs
>     ;
{txt}
{com}. local yes_coll_qs
>     where_attend_coll
>     which_uc_campus
>     which_csu_campus
>     how_sure_attend
>     coll_contact
>     coll_contact_subject
>     ;
{txt}
{com}. local tools_qs
>     helpful_source_hs helpful_source_parent
>     helpful_source_family helpful_source_friend
>     helpful_source_social helpful_source_college
>     helpful_source_private
>     ;
{txt}
{com}. local coll_exp_qs
>     highest_degree 
>     coll_worry_tuition coll_worry_living
>     coll_worry_academic coll_worry_work
>     coll_worry_family coll_worry_community
>     coll_worry_living_away coll_worry_support 
>     ;
{txt}
{com}. local hs_exp_qs
>     hs_type 
>     complete_atog track_atog 
>     dual_enr
>     dual_enr_atog
>     transcript_atog
>     ;
{txt}
{com}. local all_qs
>     `fafsa_qs' `coll_att_qs' `coll_app_qs' 
>     `not_coll_qs' `idk_coll_qs' `yes_coll_qs'
>     `tools_qs' `coll_exp_qs' `hs_exp_qs'
>     ;
{txt}
{com}. #delimit cr 
{txt}delimiter now cr
{com}. {txt}
{com}. 
. use $projdir/dta/csac_2024_initial_clean.dta, clear 
{txt}
{com}. 
. foreach var of local all_qs {c -(}
{txt}  2{com}.     foreach demog in race gender parent_edu {c -(}
{txt}  3{com}.         di "`var' by `demog'"
{txt}  4{com}.         tabulate `demog' `var'  if hs_senior==1, row 
{txt}  5{com}. 
.     {c )-}
{txt}  6{com}. 
. {c )-}
