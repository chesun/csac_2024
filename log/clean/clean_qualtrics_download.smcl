. ************ Demographics *************
. 
. // race
. rename q72 race_raw
{res}{txt}
{com}. gen black = 1 if strpos(race_raw, "Black/African American") !=0
{txt}(24,353 missing values generated)

{com}. replace black = 0 if strpos(race_raw, "Black/African American") ==0 & !mi(race_raw)
{txt}(8,045 real changes made)

{com}. 
. gen native = 1 if strpos(race_raw, "American Indian/Alaskan Native") != 0
{txt}(24,824 missing values generated)

{com}. replace native = 0 if strpos(race_raw, "American Indian/Alaskan Native") == 0 & !mi(race_raw)
{txt}(8,516 real changes made)

{com}. 
. gen asian = 1 if strpos(race_raw, "Asian") != 0
{txt}(23,699 missing values generated)

{com}. replace asian = 0 if strpos(race_raw, "Asian") ==0 & !mi(race_raw)
{txt}(7,391 real changes made)

{com}. 
. gen filipino = 1 if strpos(race_raw, "Filipino") !=0
{txt}(24,646 missing values generated)

{com}. replace filipino = 0 if strpos(race_raw, "Filipino") == 0 & !mi(race_raw)
{txt}(8,338 real changes made)

{com}. 
. gen hispanic = 1 if strpos(race_raw, "Hispanic/Latinx") != 0
{txt}(19,877 missing values generated)

{com}. replace hispanic = 0 if strpos(race_raw, "Hispanic/Latinx") == 0 & !mi(race_raw)
{txt}(3,569 real changes made)

{com}. 
. gen islander = 1 if strpos(race_raw, "Pacific Islander") !=0
{txt}(24,940 missing values generated)

{com}. replace islander = 0 if strpos(race_raw, "Pacific Islander") ==0 & !mi(race_raw)
{txt}(8,632 real changes made)

{com}. 
. gen white = 1 if strpos(race_raw, "White/Non-Hispanic") !=0
{txt}(22,975 missing values generated)

{com}. replace white = 0 if strpos(race_raw, "White/Non-Hispanic") ==0 & !mi(race_raw)
{txt}(6,667 real changes made)

{com}. 
. // count as other race only if no predefined option was selected
. gen other_race = 1 if strpos(race_raw, "Other (Please specify):") !=0 ///
>      & (black == 0) & (native == 0) & (asian == 0) & (filipino == 0)  ///
>      & (hispanic == 0) & (islander == 0) & (white == 0)
{txt}(24,848 missing values generated)

{com}. replace other_race = 0 if strpos(race_raw, "Other (Please specify):") ==0 & !mi(race_raw)
{txt}(8,416 real changes made)

{com}. 
. rename q72_8_text other_race_text
{res}{txt}
{com}. label var other_race_text "Q72: free response for race/ethnicity: other"
{txt}
{com}. 
. // limit mutlirace to people who chose two or more from predefined options 
. gen multirace = 1 if strpos(race_raw, ",") !=0
{txt}(23,778 missing values generated)

{com}. replace multirace = 0 if strpos(race_raw, ",") == 0 & !mi(race_raw) & other_race != 1
{txt}(7,290 real changes made)

{com}. 
. label define race_lab 1 "Black" 2 "Native" 3 "Asian" 4 "Filipino" 5 "Hispanic" 6 "Pacific Islander" 7 "White" 8 "Other Race" 9 "Multiracial"
{txt}
{com}. gen race = 1 if black == 1 & multirace == 0
{txt}(24,640 missing values generated)

{com}. replace race = 2 if native == 1 & multirace == 0
{txt}(29 real changes made)

{com}. replace race = 3 if asian == 1 & multirace == 0
{txt}(968 real changes made)

{com}. replace race = 4 if filipino == 1 & multirace == 0
{txt}(132 real changes made)

{com}. replace race = 5 if hispanic == 1 & multirace == 0
{txt}(4,430 real changes made)

{com}. replace race = 6 if islander == 1 & multirace == 0
{txt}(24 real changes made)

{com}. replace race = 7 if white == 1 & multirace == 0
{txt}(1,319 real changes made)

{com}. replace race = 8 if other_race == 1 & multirace == 0 
{txt}(0 real changes made)

{com}. replace race = 9 if multirace == 1
{txt}(1,250 real changes made)

{com}. label values race race_lab
{txt}
{com}. label var race "cleaned race"
{txt}
{com}. 
