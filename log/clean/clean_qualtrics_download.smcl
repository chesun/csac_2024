{smcl}
{com}{sf}{ul off}{txt}{.-}
      name:  {res}<unnamed>
       {txt}log:  {res}/home/research/ca_ed_lab/projects/csac_survey2024/log/clean/clean_qualtrics_download.smcl
  {txt}log type:  {res}smcl
 {txt}opened on:  {res} 6 Aug 2024, 19:13:26
{txt}
{com}. 
. graph drop _all
{txt}
{com}. set more off
{txt}
{com}. set varabbrev off
{txt}
{com}. set graphics off
{txt}
{com}. set scheme s1color
{txt}
{com}. set seed 1984
{txt}
{com}. 
. // this is the correct file, the older file has line breaks in text response which results in incorrect import
. import delimited "$rawdtadir/CSAC_2024_Senior_Survey_August 2, 2024_12.04.csv", varnames(1) clear 
{res}{txt}(encoding automatically selected: ISO-8859-1)
{text}(222 vars, 25,030 obs)

{com}. 
. 
. //---------------------------------------------------------------
. // initial cleaning
. // do not encode select all that apply questions
. //---------------------------------------------------------------
. // drop header rows
. drop if _n==1 | _n==2
{txt}(2 observations deleted)

{com}. // drop empty system variables
. drop recipient*name recipientemail externalreference
{txt}
{com}. 
. drop distributionchannel  
{txt}
{com}. drop *click* *pagesubmit
{txt}
{com}. 
. // rename and recode variables 
. encode q4, generate(ready_to_start) label(ready_to_start_lab)
{txt}
{com}. label var ready_to_start "Q4: Ready to start survey or show more info"
{txt}
{com}. drop q4
{txt}
{com}. 
. // remove leading and trailing spaces and convert to lower case
. replace q6 = strlower(strtrim(q6))
{txt}(3,464 real changes made)

{com}. rename q6 email 
{res}{txt}
{com}. 
. label define hs_senior_lab 0 "No" 1 "Yes"
{txt}
